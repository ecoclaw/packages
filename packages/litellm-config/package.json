{
  "name": "@gonzih/litellm-config",
  "version": "1.0.1",
  "description": "LiteLLM configuration generator with BYOK multi-model routing for ecoclaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "bin": {
    "litellm-config": "bin/litellm-config.js"
  },
  "keywords": [
    "ecoclaw",
    "litellm",
    "byok",
    "llm-routing"
  ],
  "author": "ecoclaw",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
