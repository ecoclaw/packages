{
  "name": "@gonzih/skill-discovery",
  "version": "1.0.2",
  "description": "Runtime skill manifest discovery, API key filtering, and context building for ecoclaw skill bundles",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "bin": {
    "skill-discovery": "bin/skill-discovery.js"
  },
  "keywords": [
    "ecoclaw",
    "skills",
    "byok",
    "skill-discovery"
  ],
  "author": "ecoclaw",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
